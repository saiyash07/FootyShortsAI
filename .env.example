# Server Config
PORT=8000
HOST=0.0.0.0

# Database Config
DATABASE_URL=sqlite:///./automation.db

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Google Drive Config
# The ID of the Drive folder to monitor
GOOGLE_DRIVE_FOLDER_ID=1I8FGWyUsJkQ3CqOdYv7XXNAIJsQezuvU
# The ID of the Drive folder where processed/uploaded videos should be moved (optional - if empty, code will create/find "Uploaded" inside the monitored folder)
GOOGLE_DRIVE_UPLOADED_FOLDER_ID=

# OAuth 2.0 Config
# Path to client_secrets.json from Google Cloud Console
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
# Path to token.json storing user access & refresh tokens
GOOGLE_TOKEN_FILE=token.json
